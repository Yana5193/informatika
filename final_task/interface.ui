      <property name="styleSheet">
       <string notr="true">/* Основной фон окна */
QMainWindow, QWidget {
    background-color: #F3F0F7;
    color: #2D3436;
    font-family: &quot;Segoe UI&quot;, sans-serif;
}

/* Кнопки: нежные, со скруглением */
QPushButton {
    background-color: #A29BFE;
    color: white;
    border-radius: 12px;
    padding: 10px 20px;
    font-weight: bold;
    border: none;
}

/* Эффект при наведении — кнопка становится чуть ярче */
QPushButton:hover {
    background-color: #6C5CE7;
}

/* Поля ввода (Search, Combo, Table) */
QLineEdit, QComboBox, QTableWidget, QTextBrowser {
    background-color: white;
    border: 2px solid #DCDDE1;
    border-radius: 8px;
    padding: 6px;
    color: #2D3436;
}

/* Фокус на поле ввода (когда кликаешь) */
QLineEdit:focus, QComboBox:focus {
    border: 2px solid #A29BFE;
}

/* Прогресс-бар: нежно-фиолетовый */
QProgressBar {
    border: 1px solid #DCDDE1;
    border-radius: 10px;
    text-align: center;
    background-color: #E8E4F0;
    color: #2D3436;
}

QProgressBar::chunk {
    background-color: #A29BFE;
    border-radius: 9px;
}

/* Стиль таблицы */
QHeaderView::section {
    background-color: #F8F9FA;
    padding: 4px;
    border: 1px solid #DCDDE1;
    font-weight: bold;
}</string>
